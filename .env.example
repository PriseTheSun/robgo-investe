# GEMINI_API_KEY: Required for Gemini AI API calls.
# This variable is injected at runtime.
# Configure this via your environment variables or .env file.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this project is hosted.
# This variable is injected at runtime.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# BRAPI_TOKEN: API Key for the brapi.dev finance data provider.
# Required to fetch stock values and external data locally and in production.
BRAPI_TOKEN="SUA_CHAVE_BRAPI_AQUI"
