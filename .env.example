# GEMINI_API_KEY: Required for Gemini AI API calls.
# This variable is injected at runtime.
# Configure this via your environment variables or .env file.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this project is hosted.
# This variable is injected at runtime.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
